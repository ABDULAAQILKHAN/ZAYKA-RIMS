{
  "name": "zayka",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:app": "turbo run dev --filter=@zayka/app",
    "dev:rims": "turbo run dev --filter=@zayka/rims",
    "build:app": "turbo run build --filter=@zayka/app",
    "build:rims": "turbo run build --filter=@zayka/rims",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.2.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  }
}
